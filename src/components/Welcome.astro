---
import CliPrefix from "./CliPrefix.astro";
import SocialLinks from "./SocialLinks.astro";
import Contact from "./Contact.astro";
---

<main id="container">
	<CliPrefix useCaret={true}>
		<p>me --help</p>
	</CliPrefix>

	<div class="fade-in">
		<div class="shade" />
		<SocialLinks />
		<p>
			I'm a frontend-focused software developer based in Brazil, specializing in
			building modern, scalable, and user-centered interfaces with React and
			TypeScript. I also have experience working across the stack using Node.js and
			Ruby on Rails.
		</p>
		<p>
			I enjoy working in agile environments and collaborating closely with designers,
			product managers, and other engineers to turn ideas into reliable, high-quality
			products. Currently, I contribute to an international SaaS platform focused on
			qualitative and quantitative research.
		</p>
		<p>
			My background spans both consulting and product-driven teams, which helped me
			develop strong problem-solving skills, adaptability, and a practical mindset
			when building software that delivers real value to users.
		</p>
		<CliPrefix>
			<p>contact</p>
		</CliPrefix>
		<Contact />
	</div>
</main>

<style>
	#container {
		max-width: 80ch;
		height: 100%;
		padding: 24px;
		overflow: hidden;
	}

	.shade {
		position: absolute;
		width: 100%;
		height: 100%;
		background-color: #211925;
		animation: fallDown 1.8s 1.5s forwards;
	}

	p {
		line-height: 1.6;
		color: #e9e9f4;
	}

	.fade-in {
		position: relative;
		overflow: hidden;
		opacity: 0;
		height: 100%;
		animation: fadeIn 1.8s 1.5s forwards;
	}

	@keyframes fadeIn {
		to {
			opacity: 1;
		}
	}

	@keyframes fallDown {
		to {
			transform: translateY(100%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.fade-in {
			opacity: 1;
		}
	}
</style>
